include README.md
include POLYHORIZON.md
include ROADMAP.md
include CHANGELOG.md
include LICENSE
include SECURITY.md
include CONTRIBUTING.md
include public-boundary.toml
recursive-include .githooks pre-commit pre-push
recursive-include docs *.md
recursive-include examples *.json *.md *.mjs *.py
recursive-include schemas *.json
recursive-include scripts *.py *.sh
recursive-include tests *.py
prune .claude
prune .codex
prune .polyhorizon
prune .ua
prune .understand-anything
prune internal
prune docs/internal
prune worklogs
global-exclude .env .env.* .envrc *.local.*
