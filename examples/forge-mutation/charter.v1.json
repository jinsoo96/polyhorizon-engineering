{
  "api_version": "polyhorizon.charter/v0.1",
  "id": "production-forge-charter",
  "revision": "1.0.0",
  "description": "Predecessor charter governing Forge mutations to a production agent harness.",
  "principals": [
    {
      "id": "governance-root",
      "trust_domain": "governance",
      "adapter": "local:governance",
      "description": "External amendment root outside the Forge control loop."
    },
    {
      "id": "forge-controller",
      "trust_domain": "forge",
      "adapter": "local:forge"
    },
    {
      "id": "ops-observer",
      "trust_domain": "operations",
      "adapter": "local:telemetry"
    },
    {
      "id": "safety-observer",
      "trust_domain": "safety",
      "adapter": "local:safety-case"
    },
    {
      "id": "user-representative",
      "trust_domain": "affected-users",
      "adapter": "local:user-panel"
    },
    {
      "id": "rollback-executor",
      "trust_domain": "recovery",
      "adapter": "local:rollback"
    }
  ],
  "purposes": [
    {
      "id": "safe-self-improvement",
      "owner": "governance-root",
      "specification_digest": "sha256:972223fb48402e48789f11c812783a34a69516462e51e9b8b36af9233201ac99",
      "description": "Improve the harness without hiding consequences outside the Forge score."
    }
  ],
  "horizons": [
    {
      "id": "horizon.authority",
      "kind": "authority",
      "owner": "governance-root",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "observers": ["governance-root"],
      "minimum_trust_domains": 1
    },
    {
      "id": "horizon.causal",
      "kind": "causal",
      "owner": "safety-observer",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "observers": ["ops-observer", "safety-observer"],
      "minimum_trust_domains": 2
    },
    {
      "id": "horizon.epistemic",
      "kind": "epistemic",
      "owner": "safety-observer",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "observers": ["ops-observer", "safety-observer"],
      "minimum_trust_domains": 2
    },
    {
      "id": "horizon.stakeholder",
      "kind": "stakeholder",
      "owner": "user-representative",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "observers": ["user-representative"],
      "minimum_trust_domains": 1
    },
    {
      "id": "horizon.temporal",
      "kind": "temporal",
      "owner": "ops-observer",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "observers": ["ops-observer", "safety-observer"],
      "minimum_trust_domains": 2
    }
  ],
  "standings": [
    {
      "id": "governors",
      "representatives": ["governance-root"],
      "rights": ["right.ratify", "right.veto"]
    },
    {
      "id": "operators",
      "representatives": ["ops-observer"],
      "rights": ["right.appeal", "right.rollback"]
    },
    {
      "id": "users",
      "representatives": ["user-representative"],
      "rights": ["right.appeal", "right.explanation", "right.exit"]
    }
  ],
  "recourses": [
    {
      "id": "rollback-governors",
      "standing_id": "governors",
      "owner": "governance-root",
      "executor": "rollback-executor",
      "mechanism": "automatic.rollback",
      "applies_to": ["compensatable", "irreversible"],
      "deadline_seconds": 3600
    },
    {
      "id": "rollback-operators",
      "standing_id": "operators",
      "owner": "governance-root",
      "executor": "rollback-executor",
      "mechanism": "automatic.rollback",
      "applies_to": ["compensatable", "irreversible"],
      "deadline_seconds": 3600
    },
    {
      "id": "rollback-users",
      "standing_id": "users",
      "owner": "governance-root",
      "executor": "rollback-executor",
      "mechanism": "automatic.rollback",
      "applies_to": ["compensatable", "irreversible"],
      "deadline_seconds": 3600
    }
  ],
  "obligations": [
    {
      "id": "obligation.authorized-change",
      "horizon_id": "horizon.authority",
      "bearer": "forge-controller",
      "beneficiary": "governors",
      "predicate": "predicate.change-authorized",
      "mode": "hard",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "recourse_ids": ["rollback-governors"],
      "observer_ids": ["governance-root"]
    },
    {
      "id": "obligation.causal-isolation",
      "horizon_id": "horizon.causal",
      "bearer": "forge-controller",
      "beneficiary": "users",
      "predicate": "predicate.no-cross-service-regression",
      "mode": "hard",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "recourse_ids": ["rollback-users"],
      "observer_ids": ["ops-observer", "safety-observer"]
    },
    {
      "id": "obligation.evidence-complete",
      "horizon_id": "horizon.epistemic",
      "bearer": "forge-controller",
      "beneficiary": "operators",
      "predicate": "predicate.heldout-evidence-complete",
      "mode": "review",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "recourse_ids": ["rollback-operators"],
      "observer_ids": ["ops-observer", "safety-observer"]
    },
    {
      "id": "obligation.no-user-regression",
      "horizon_id": "horizon.stakeholder",
      "bearer": "forge-controller",
      "beneficiary": "users",
      "predicate": "predicate.no-material-user-regression",
      "mode": "hard",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "recourse_ids": ["rollback-users"],
      "observer_ids": ["user-representative"]
    },
    {
      "id": "obligation.rollback-window",
      "horizon_id": "horizon.temporal",
      "bearer": "forge-controller",
      "beneficiary": "operators",
      "predicate": "predicate.rollback-window-24h",
      "mode": "hard",
      "selectors": {
        "effects": ["forge.*"],
        "resources": ["harness/*"]
      },
      "recourse_ids": ["rollback-operators"],
      "observer_ids": ["ops-observer", "safety-observer"]
    }
  ],
  "mandates": [
    {
      "id": "mandate.forge-production",
      "issuer": "governance-root",
      "principal": "forge-controller",
      "actions": ["forge.*"],
      "resources": ["harness/*"],
      "issued_at": "2026-01-01T00:00:00Z",
      "expires_at": "2099-01-01T00:00:00Z",
      "allow_amendment": true
    }
  ],
  "amendment": {
    "approver_standings": ["governors", "operators", "users"],
    "minimum_standings": 2,
    "root_principal": "governance-root"
  }
}
