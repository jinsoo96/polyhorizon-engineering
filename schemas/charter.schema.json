{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/jinsoo96/polyhorizon-engineering/main/schemas/charter.schema.json",
  "title": "Polyhorizon Charter v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "id",
    "revision",
    "principals",
    "purposes",
    "horizons",
    "standings",
    "obligations",
    "recourses",
    "mandates",
    "amendment"
  ],
  "properties": {
    "api_version": { "const": "polyhorizon.charter/v0.1" },
    "id": { "$ref": "#/$defs/identifier" },
    "revision": { "$ref": "#/$defs/identifier" },
    "principals": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/principal" }
    },
    "purposes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/purpose" }
    },
    "horizons": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/horizon" }
    },
    "standings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/standing" }
    },
    "obligations": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/obligation" }
    },
    "recourses": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/recourse" }
    },
    "mandates": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/mandate" }
    },
    "amendment": { "$ref": "#/$defs/amendment" },
    "description": { "type": "string" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}$"
    },
    "selector": {
      "type": "string",
      "pattern": "^(?:\\*|[A-Za-z0-9][A-Za-z0-9._:/-]{0,126}\\*?)$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?(Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "selectors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effects", "resources"],
      "properties": {
        "effects": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/selector" }
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/selector" }
        }
      }
    },
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "trust_domain", "adapter"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "trust_domain": { "$ref": "#/$defs/identifier" },
        "adapter": { "$ref": "#/$defs/identifier" },
        "description": { "type": "string" }
      }
    },
    "purpose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "owner", "specification_digest"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "owner": { "$ref": "#/$defs/identifier" },
        "specification_digest": { "$ref": "#/$defs/digest" },
        "description": { "type": "string" }
      }
    },
    "horizon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "owner",
        "selectors",
        "observers",
        "minimum_trust_domains"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "kind": { "$ref": "#/$defs/identifier" },
        "owner": { "$ref": "#/$defs/identifier" },
        "selectors": { "$ref": "#/$defs/selectors" },
        "observers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "minimum_trust_domains": { "$ref": "#/$defs/positiveInteger" },
        "description": { "type": "string" }
      }
    },
    "standing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "representatives", "rights"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "representatives": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "rights": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "description": { "type": "string" }
      }
    },
    "recourse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "standing_id",
        "owner",
        "executor",
        "mechanism",
        "applies_to",
        "deadline_seconds"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "standing_id": { "$ref": "#/$defs/identifier" },
        "owner": { "$ref": "#/$defs/identifier" },
        "executor": { "$ref": "#/$defs/identifier" },
        "mechanism": { "$ref": "#/$defs/identifier" },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["reversible", "compensatable", "irreversible"]
          }
        },
        "deadline_seconds": { "$ref": "#/$defs/positiveInteger" },
        "description": { "type": "string" }
      }
    },
    "obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "horizon_id",
        "bearer",
        "beneficiary",
        "predicate",
        "mode",
        "selectors"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "horizon_id": { "$ref": "#/$defs/identifier" },
        "bearer": { "$ref": "#/$defs/identifier" },
        "beneficiary": { "$ref": "#/$defs/identifier" },
        "predicate": { "$ref": "#/$defs/identifier" },
        "mode": { "enum": ["hard", "review", "advisory"] },
        "selectors": { "$ref": "#/$defs/selectors" },
        "recourse_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "observer_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "description": { "type": "string" }
      }
    },
    "mandate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "issuer",
        "principal",
        "actions",
        "resources",
        "issued_at",
        "expires_at"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "issuer": { "$ref": "#/$defs/identifier" },
        "principal": { "$ref": "#/$defs/identifier" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/selector" }
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/selector" }
        },
        "issued_at": { "$ref": "#/$defs/timestamp" },
        "expires_at": { "$ref": "#/$defs/timestamp" },
        "allow_amendment": { "type": "boolean" }
      }
    },
    "amendment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approver_standings", "minimum_standings", "root_principal"],
      "properties": {
        "approver_standings": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "minimum_standings": { "$ref": "#/$defs/positiveInteger" },
        "root_principal": { "$ref": "#/$defs/identifier" }
      }
    }
  }
}
