{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/jinsoo96/polyhorizon-engineering/main/schemas/wire.schema.json",
  "title": "Polyhorizon NDJSON Envelope v0.1",
  "oneOf": [
    { "$ref": "#/$defs/capabilitiesRequest" },
    { "$ref": "#/$defs/openRequest" },
    { "$ref": "#/$defs/advanceRequest" },
    { "$ref": "#/$defs/inspectRequest" },
    { "$ref": "#/$defs/abortRequest" },
    { "$ref": "#/$defs/successResponse" },
    { "$ref": "#/$defs/errorResponse" }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "capabilitiesRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "request_id", "command", "payload"],
      "properties": {
        "api_version": { "const": "polyhorizon.wire/v0.1" },
        "request_id": { "$ref": "#/$defs/identifier" },
        "command": { "const": "capabilities" },
        "payload": {
          "type": "object",
          "maxProperties": 0
        }
      }
    },
    "openRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "request_id", "command", "payload"],
      "properties": {
        "api_version": { "const": "polyhorizon.wire/v0.1" },
        "request_id": { "$ref": "#/$defs/identifier" },
        "command": { "const": "open" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["charter", "proposal"],
          "properties": {
            "charter": { "$ref": "charter.schema.json" },
            "proposal": { "$ref": "proposal.schema.json" },
            "candidate": {
              "oneOf": [
                { "$ref": "charter.schema.json" },
                { "type": "null" }
              ]
            }
          }
        }
      }
    },
    "advanceRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "request_id", "command", "payload"],
      "properties": {
        "api_version": { "const": "polyhorizon.wire/v0.1" },
        "request_id": { "$ref": "#/$defs/identifier" },
        "command": { "const": "advance" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["charter", "session_id", "expected_sequence", "receipts"],
          "properties": {
            "charter": { "$ref": "charter.schema.json" },
            "session_id": { "$ref": "#/$defs/identifier" },
            "expected_sequence": { "$ref": "#/$defs/sequence" },
            "receipts": {
              "type": "array",
              "uniqueItems": true,
              "items": { "$ref": "effect-receipt.schema.json" }
            }
          }
        }
      }
    },
    "inspectRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "request_id", "command", "payload"],
      "properties": {
        "api_version": { "const": "polyhorizon.wire/v0.1" },
        "request_id": { "$ref": "#/$defs/identifier" },
        "command": { "const": "inspect" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["session_id"],
          "properties": {
            "session_id": { "$ref": "#/$defs/identifier" }
          }
        }
      }
    },
    "abortRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "request_id", "command", "payload"],
      "properties": {
        "api_version": { "const": "polyhorizon.wire/v0.1" },
        "request_id": { "$ref": "#/$defs/identifier" },
        "command": { "const": "abort" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["session_id", "expected_sequence"],
          "properties": {
            "session_id": { "$ref": "#/$defs/identifier" },
            "expected_sequence": { "$ref": "#/$defs/sequence" }
          }
        }
      }
    },
    "successResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "request_id", "ok", "payload"],
      "properties": {
        "api_version": { "const": "polyhorizon.wire/v0.1" },
        "request_id": { "$ref": "#/$defs/identifier" },
        "ok": { "const": true },
        "payload": { "type": "object" }
      }
    },
    "errorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api_version", "request_id", "ok", "error"],
      "properties": {
        "api_version": { "const": "polyhorizon.wire/v0.1" },
        "request_id": { "$ref": "#/$defs/identifier" },
        "ok": { "const": false },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "$ref": "#/$defs/identifier" },
            "message": { "type": "string" }
          }
        }
      }
    }
  }
}
